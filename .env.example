# Copy to .env for local development. NEVER commit real secrets.
NODE_ENV=development
PORT=4000

# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cardioai?schema=public"

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="replace-with-long-random-string"
JWT_EXPIRES_IN="30m"

# PHI field-level encryption (AES-256-GCM). 32 bytes, base64.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PHI_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# CORS — only needed in dev (Vite runs the client on a different origin).
# In production the API serves the client same-origin, so this is unused.
CORS_ORIGIN="http://localhost:5173"

# Seed synthetic demo data on boot (set false in production once seeded)
SEED_ON_BOOT=true
